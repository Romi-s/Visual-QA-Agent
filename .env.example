# Choose your provider: "anthropic" or "openai"
PROVIDER=anthropic

# Anthropic settings (required when PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI settings (required when PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4

# File limits
MAX_FILE_SIZE_MB=20
MAX_PDF_PAGES=20
IMAGE_RENDER_DPI=150
